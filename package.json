{
  "name": "ma-studio",
  "version": "0.1.0",
  "description": "\u9593 (Ma) \u2014 Ableton Live Lite automation wrapper. Zen music creation.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "build:renderer": "vite build",
    "preview": "vite preview",
    "package": "electron-builder --mac",
    "lint": "eslint src/"
  },
  "build": {
    "appId": "com.ma.studio",
    "productName": "Ma",
    "mac": {
      "category": "public.app-category.music",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "darkModeSupport": true,
      "hardenedRuntime": true
    },
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chokidar": "^4.0.0",
    "electron-store": "^10.0.0",
    "fast-xml-parser": "^5.0.0",
    "fflate": "^0.8.2",
    "glob": "^11.0.0",
    "jzz": "^1.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "framer-motion": "^12.0.0",
    "zustand": "^5.0.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "type": "module"
}